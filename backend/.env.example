# ==============================
# Server
# ==============================
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ==============================
# Database
# ==============================
MONGO_URI=mongodb://localhost:27017/healthcare_appointments

# ==============================
# Auth
# ==============================
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ==============================
# LLM (Anthropic Claude) - Pre/Post visit summaries
# If ANTHROPIC_API_KEY is left blank, the app runs in MOCK mode
# and returns deterministic canned summaries so the rest of the
# system keeps working without a real key.
# ==============================
ANTHROPIC_API_KEY=
LLM_MODE=mock
# LLM_MODE=live   <-- switch to this once ANTHROPIC_API_KEY is set

# ==============================
# Email (choose ONE provider; Nodemailer supports all of these)
# If EMAIL_MODE=mock, emails are logged to console + saved in DB
# instead of actually being sent. Switch to "live" once creds are set.
# ==============================
EMAIL_MODE=mock
EMAIL_PROVIDER=smtp
# --- SMTP / Nodemailer generic ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# --- SendGrid (alternative, set EMAIL_PROVIDER=sendgrid) ---
SENDGRID_API_KEY=
EMAIL_FROM="Clinic Care <no-reply@clinic.example.com>"

# ==============================
# Google Calendar (OAuth 2.0)
# If GOOGLE_CALENDAR_MODE=mock, calendar events are simulated and
# stored in DB with a fake link instead of calling the real API.
# ==============================
GOOGLE_CALENDAR_MODE=mock
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ==============================
# Background Jobs
# ==============================
REMINDER_CRON=*/15 * * * *
EMAIL_RETRY_CRON=*/10 * * * *
MAX_EMAIL_RETRIES=3
